# Database (use postgresql+asyncpg:// scheme for async SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/auth_server

# Session signing key (use a long random string in production)
SESSION_SECRET_KEY=change-me-to-a-long-random-string

# Resend (https://resend.com)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# OTP settings
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=10
